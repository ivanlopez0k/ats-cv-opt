# ============================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================

# ============================================================
# API URL (Backend endpoint)
# ============================================================
# Development:
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Production (example for Vercel):
# NEXT_PUBLIC_API_URL=https://your-backend-api.example.com/api

# ============================================================
# OTHER NEXT.JS CONFIG
# ============================================================
# These are automatically set by Vercel in production
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# NEXT_PUBLIC_API_URL is the only one you typically need to set manually