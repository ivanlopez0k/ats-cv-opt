# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/cvmaster"
REDIS_URL="redis://localhost:6379"

# ============================================================
# JWT / AUTH
# ============================================================
# IMPORTANT: Use different secrets for access and refresh tokens in production
JWT_SECRET="your-access-token-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-different-from-access"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# OPENAI
# ============================================================
OPENAI_API_KEY="sk-your-openai-api-key"

# ============================================================
# OLLAMA (local, free AI — alternative to OpenAI)
# ============================================================
# Set to 'true' to use a local Ollama instance instead of OpenAI.
# Requires Ollama installed and a model pulled (e.g., qwen3:8b).
OLLAMA_ENABLED=false
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:8b"

# ============================================================
# CLOUDINARY
# ============================================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY="re_your-api-key"
RESEND_FROM_EMAIL="noreply@cvmaster.com"

# ============================================================
# FRONTEND URL
# ============================================================
FRONTEND_URL="http://localhost:3000"

# ============================================================
# COOKIE (for secure cookie mode)
# ============================================================
COOKIE_SECRET="your-cookie-secret-for-signed-cookies"

# ============================================================
# PRODUCTION RECOMMENDATIONS
# ============================================================
# For production deployment, enable these settings:
# SECURITY_SECURE_COOKIES=true         # Use HttpOnly cookies instead of localStorage
# SECURITY_RATE_LIMIT=true             # Protect against brute force
# SECURITY_PASSWORD_STRENGTH=true      # Enforce strong passwords
# SECURITY_ACCOUNT_LOCKOUT=true        # Lock account after failed attempts
# SECURITY_EMAIL_VERIFICATION=true     # Require email verification
# SECURITY_AUDIT_LOG=true              # Log security events
# SECURITY_TOKEN_REUSE_DETECTION=true  # Detect token theft

# ============================================================
# SECURITY TOGGLES
# All default to 'false' for fast development/testing.
# Set to 'true' in production.
# ============================================================

# Rate limiting on auth endpoints (brute force protection)
SECURITY_RATE_LIMIT=false

# Strong password requirements (uppercase, number, special char)
SECURITY_PASSWORD_STRENGTH=false

# Account lockout after failed login attempts
SECURITY_ACCOUNT_LOCKOUT=false
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# Refresh token reuse detection (theft indicator)
SECURITY_TOKEN_REUSE_DETECTION=false

# Email verification required for full access
SECURITY_EMAIL_VERIFICATION=false

# Security event audit logging
SECURITY_AUDIT_LOG=false

# HttpOnly Secure Cookies instead of JSON body tokens
SECURITY_SECURE_COOKIES=false

# ============================================================
# DEVELOPMENT MODELS (no API credits needed)
# ============================================================
# Set to 'true' to generate random mock analysis results.
# Useful when you don't have OpenAI credits and don't use Ollama.
OPENAI_MOCK_ENABLED=false
