# ============================================================
# ENVIRONMENT
# ============================================================
NODE_ENV=development  # Set to 'production' in prod
PORT=4000

# ============================================================
# DATABASE (Neon PostgreSQL recommended)
# ============================================================
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# REDIS (Required for rate limiting in production)
# ============================================================
# Free options: Upstash (upstash.com), Railway ($5 credit)
REDIS_URL="redis://localhost:6379"

# ============================================================
# JWT / AUTH
# ============================================================
# ⚠️ IMPORTANT: Generate secure random secrets for production:
# Access token secret (minimum 256 bits):
JWT_SECRET="generate-a-secure-random-string-here-min-32-chars"
# Refresh token secret (different from access):
JWT_REFRESH_SECRET="another-secure-random-string-different-from-above"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# OPENAI
# ============================================================
OPENAI_API_KEY="sk-your-openai-api-key"

# ============================================================
# OLLAMA (local, free AI — alternative to OpenAI)
# ============================================================
# Set to 'true' to use a local Ollama instance instead of OpenAI.
# Requires Ollama installed and a model pulled (e.g., qwen3:8b).
OLLAMA_ENABLED=false
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:8b"

# ============================================================
# CLOUDINARY
# ============================================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY="re_your-api-key"
RESEND_FROM_EMAIL="noreply@cvmaster.com"

# ============================================================
# FRONTEND URL (for CORS and redirects)
# ============================================================
# Change to your production frontend URL when deploying
FRONTEND_URL="http://localhost:3000"
# Example for Vercel: FRONTEND_URL="https://your-app.vercel.app"

# ============================================================
# API VERSION
# ============================================================
API_VERSION="v1"

# ============================================================
# COOKIE (for secure cookie mode)
# ============================================================
COOKIE_SECRET="your-cookie-secret-for-signed-cookies"

# ============================================================
# SECURITY TOGGLES
# ============================================================
# ⚠️ IMPORTANT: Enable these for production deployment!
# Development defaults are 'false' for fast testing.

# Rate limiting on auth endpoints (brute force protection)
SECURITY_RATE_LIMIT=true

# Strong password requirements (uppercase, number, special char)
SECURITY_PASSWORD_STRENGTH=true

# Account lockout after failed login attempts
SECURITY_ACCOUNT_LOCKOUT=true
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# Refresh token reuse detection (theft indicator)
SECURITY_TOKEN_REUSE_DETECTION=true

# Email verification required for full access (optional)
SECURITY_EMAIL_VERIFICATION=false

# Security event audit logging
SECURITY_AUDIT_LOG=true

# ⚠️ HttpOnly Secure Cookies - RECOMMENDED for production
# When enabled, tokens are sent in HttpOnly cookies, not JSON body
SECURITY_SECURE_COOKIES=true

# ============================================================
# DEVELOPMENT MODELS (no API credits needed)
# ============================================================
# Set to 'true' to generate random mock analysis results.
# Useful when you don't have OpenAI credits and don't use Ollama.
OPENAI_MOCK_ENABLED=false
